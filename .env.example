# Chave principal da API (obrigatória)
API_KEY=change-this-to-a-strong-random-api-key

# Opcional: chave específica para o frontend (se vazio, usa API_KEY)
CORE_API_KEY=

# Opcional para o frontend local (site.financial). Default no dev: http://localhost:3000
CORE_API_BASE_URL=http://localhost:3000

# Supabase (forma canônica)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Aliases também aceitos pelo projeto (compatível com env vindo da Vercel/Next/Vite)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# CORS
CORS_ALLOW_ORIGIN=*

# Opcional: usado por alguns fluxos do Vercel CLI
VERCEL_OIDC_TOKEN=
